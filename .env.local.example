# Variáveis do Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Conexão direta com PostgreSQL (necessário para Prisma migrations, seed e scripts)
# Pegar em: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Formato: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.your-project-ref.supabase.co:5432/postgres

# Variáveis do Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_BUCKET_NAME=your-r2-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
NEXT_PUBLIC_R2_PUBLIC_DOMAIN=https://your-r2-public-domain

# Paper MCP (for Paper MCP server integration)
# URL of the Paper MCP HTTP endpoint (e.g. http://127.0.0.1:29979/mcp)
PAPER_MCP_URL=http://127.0.0.1:29979/mcp
# Optional: Bearer token if your MCP server requires auth
PAPER_MCP_TOKEN=

# Criptografia de dados bancários (AES-256-GCM)
# Gerar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=4194fe3adc3078e7ca8250edd41f8e1d2cace7c2a2120e64e05f68df09e9b17f

# Brevo — emails transacionais
# API Key gerada em: Brevo Dashboard → Settings → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx
BREVO_FROM_EMAIL=no-reply@monarca.com.py
BREVO_FROM_NAME=Monarca Semijoyas

# Site URL (usado em links de emails e redirects do Supabase Auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
