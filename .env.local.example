# Variáveis do Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Variáveis do Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_BUCKET_NAME=your-r2-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
NEXT_PUBLIC_R2_PUBLIC_DOMAIN=https://your-r2-public-domain

# Paper MCP (for Paper MCP server integration)
# URL of the Paper MCP HTTP endpoint (e.g., http://127.0.0.1:29979/mcp)
PAPER_MCP_URL=http://127.0.0.1:29979/mcp
# Optional: Bearer token if your MCP server requires auth
PAPER_MCP_TOKEN=
